{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zade",
  "version": "0.4.0",
  "identifier": "ai.zade.shell",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; media-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzRjk3Q0I4Q0Q3RkFDQjUKUldTMXJIL051SHo1VTdUYmFqdCtOK2dSSGtYa2JUMEIwVmlkNnFVUlBpbCsva0djdHJCcGFuNFIK",
      "endpoints": [
        "http://127.0.0.1:8787/shell/latest.json"
      ],
      "dangerousInsecureTransportProtocol": true
    }
  }
}
